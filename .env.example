# Bayaan-web environment variables
# Copy this file to .env.local and fill in the values needed for your setup.

# ── Site ──────────────────────────────────────────────────────────────────────
# Public base URL of this deployment (used for canonical links, OG metadata,
# sharing URLs). Leave unset in local dev to default to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# Shown in the footer/about page. Defaults to the build commit SHA when unset.
NEXT_PUBLIC_APP_VERSION=

# ── Bayaan Backend API ────────────────────────────────────────────────────────
# Public-facing API URL consumed from the browser and server. When blank the
# app runs with bundled fallback data (no reciter catalogue network calls).
NEXT_PUBLIC_BAYAAN_API_URL=

# CDN base for reciter audio + images. Only needed if your deployment serves
# media from a different host than NEXT_PUBLIC_BAYAAN_API_URL.
NEXT_PUBLIC_BAYAAN_CDN_URL=

# Internal API URL used by server-side routes (proxying to the backend via a
# private network). When blank, server-side code falls back to the public
# NEXT_PUBLIC_BAYAAN_API_URL.
BAYAAN_INTERNAL_API_URL=

# Bearer token for the Bayaan API. Required to load the live reciter catalogue.
# Leave blank to use bundled fallback data instead.
BAYAAN_API_KEY=

# ── Android App Links verification (optional) ─────────────────────────────────
# SHA-256 certificate fingerprint of the Android app signing key. Embedded in
# /.well-known/assetlinks.json so Android can verify deep links into the app.
# Leave blank if you're not running the companion Android app against this
# domain.
ANDROID_SHA256_CERT=
