# Bayaan-web environment variables
# Copy this file to .env.local and fill in the values needed for your setup.
# None of these are required — the app boots and runs without any env file.

# ── Site ──────────────────────────────────────────────────────────────────────
# Public base URL of this deployment (used for canonical links, OG metadata,
# sharing URLs). Leave unset in local dev to default to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# Shown in the settings/about page. Defaults to the build commit SHA when unset.
NEXT_PUBLIC_APP_VERSION=

# ── Bayaan Backend API ────────────────────────────────────────────────────────
# Public-facing API URL consumed from the browser and server. When blank, server
# routes default to https://api.thebayaan.com.
NEXT_PUBLIC_BAYAAN_API_URL=

# CDN base for reciter audio + images. Only needed if your deployment serves
# media from a different host than NEXT_PUBLIC_BAYAAN_API_URL.
NEXT_PUBLIC_BAYAAN_CDN_URL=

# Internal API URL used by server-side routes (proxying to the backend via a
# private network). When blank, server-side code falls back to the public
# NEXT_PUBLIC_BAYAAN_API_URL (or https://api.thebayaan.com).
BAYAAN_INTERNAL_API_URL=

# Bearer token for the Bayaan API. Required for the reciter catalogue, audio
# playback, and timestamps. Quran reading, mushaf, adhkar, and library features
# work without it.
BAYAAN_API_KEY=

# ── Branding (optional) ───────────────────────────────────────────────────────
# All values below flow through src/config/branding.ts. If you set
# NEXT_PUBLIC_APP_NAME, the new name reaches page titles, OG, manifest, and
# About copy automatically — no need to grep for "Bayaan" across the codebase.
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_APP_TAGLINE=
NEXT_PUBLIC_SOURCE_REPO_URL=
NEXT_PUBLIC_SUPPORT_URL=
NEXT_PUBLIC_TERMS_URL=
NEXT_PUBLIC_PRIVACY_URL=

# ── Mobile deep links (optional) ──────────────────────────────────────────────
# Set only if your fork has shipped a companion iOS or Android app.
# When unset:
#   • the apple-itunes-app smart banner is omitted (so iOS visitors are NOT
#     bannered into the upstream Bayaan iOS app)
#   • /.well-known/apple-app-site-association returns 404
#   • /.well-known/assetlinks.json returns 404
NEXT_PUBLIC_IOS_APP_ID=
NEXT_PUBLIC_IOS_APP_URL=
APPLE_TEAM_ID=
IOS_BUNDLE_ID=
ANDROID_PACKAGE_NAME=

# SHA-256 certificate fingerprint of the Android app signing key. Embedded in
# /.well-known/assetlinks.json so Android can verify deep links into the app.
ANDROID_SHA256_CERT=
